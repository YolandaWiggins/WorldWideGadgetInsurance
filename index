                  <SelectValue placeholder="Select Coverage Plan" />
                </SelectTrigger>
                <SelectContent>
                  <SelectItem value="Basic">Basic - $9.99/month</SelectItem>
                  <SelectItem value="Premium">Premium - $19.99/month</SelectItem>
                  <SelectItem value="Global Elite">Global Elite - $29.99/month</SelectItem>
                </SelectContent>
